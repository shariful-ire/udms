# ============================================================
# UDMS — Environment Variables Reference
# Copy to .env and fill in values before starting.
# Never commit .env to version control.
# ============================================================

# ─── Application ─────────────────────────────────────────────
APP_NAME="University Dining Management System"
APP_VERSION="1.0.0"
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # Set false in production
SECRET_KEY=your-secret-key-here  # At least 32 random chars

# ─── Database (XAMPP MySQL) ───────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=udms

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Email (SMTP) ─────────────────────────────────────────────
MAIL_FROM=shariful.ire.dev@gmail.com
MAIL_FROM_NAME="UDMS — University Dining"
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=shariful.ire.dev@gmail.com
MAIL_PASSWORD=hwmw lkjw adxo xxqk
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=["localhost","127.0.0.1","*"]

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/hour
RATE_LIMIT_PASSWORD_RESET=3/hour
RATE_LIMIT_GLOBAL=300/minute

# ─── File Uploads ────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# ─── Argon2 ──────────────────────────────────────────────────
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2

# ─── OTP ─────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=900        # 15 minutes
OTP_RESET_EXPIRY_SECONDS=600  # 10 minutes
OTP_COOLDOWN_SECONDS=60       # Resend cooldown

# ─── Account Lockout ─────────────────────────────────────────
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
